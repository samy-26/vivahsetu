# ─────────────────────────────────────────────
# VivahSetu - Environment Configuration
# Copy to apps/backend/.env and fill in values
# ─────────────────────────────────────────────

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (MySQL)
DATABASE_URL="mysql://root:password@localhost:3306/vivahsetu"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Razorpay
RAZORPAY_KEY_ID=rzp_test_SYxr0YgtKbfv12
RAZORPAY_KEY_SECRET=ecKCqlKXtQrRR2RQHzJY2SKU
RAZORPAY_WEBHOOK_SECRET=SUcyXI8Fv8rM6s

# AWS S3 (for file storage)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=vivahsetu-files
AWS_SES_FROM_EMAIL=noreply@vivahsetu.com

# SMTP (for development - use Gmail or Mailtrap)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Security
AADHAAR_ENCRYPTION_KEY=your-32-character-encryption-key!!

# OTP
OTP_EXPIRY_MINUTES=10
